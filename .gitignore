# Rust
/target
**/*.rs.bk
Cargo.lock.bak
*.tmp.*

# Release artifacts (built by release/build.sh; published to GitHub Releases)
/dist/

# Editors / OS
*.swp
.idea/
.vscode/
.DS_Store

# JS / console (apps/console)
node_modules/
.vite/
*.log

# Generated wasm bindings (regenerated by `wasm-pack build`)
crates/vrules-wasm/pkg/
crates/em-log-n-wasm/pkg/
apps/console/src/lib/pkg/

# apps/console/dist/ is intentionally TRACKED — the native shim embeds it via include_dir!.
# Override the global gitignore's `dist/` rule (re-include the dir, then its contents).
!apps/console/dist/
!apps/console/dist/**
